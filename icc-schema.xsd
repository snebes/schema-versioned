        <xs:documentation>Metadata: Container for meta information of associate element.</xs:documentation>
      </xs:appinfo>
    </xs:annotation>
    <xs:complexType>
      <xs:choice minOccurs="1" maxOccurs="unbounded">
        <xs:element ref="meta"/>
        <xs:element ref="isbn"/>
      </xs:choice>
      <xs:attributeGroup ref="common-attributes"/>
    </xs:complexType>
  </xs:element>

