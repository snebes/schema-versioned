      </xs:appinfo>
    </xs:annotation>
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="titlepage" minOccurs="0"/>
        <xs:element ref="copyright-page" minOccurs="0"/>
        <xs:element ref="publisher-note" minOccurs="0"/>
        <xs:element ref="foreword" minOccurs="0"/>
        <xs:element ref="preface" minOccurs="0"/>
        <xs:element ref="relocation-table" minOccurs="0"/>
        <xs:choice minOccurs="0" maxOccurs="unbounded">
          <xs:element ref="section"/>
          <xs:element ref="editorial-commentary"/>
        </xs:choice>
        <xs:element ref="toc" minOccurs="0"/>
      </xs:sequence>
      <xs:attributeGroup ref="id-attributes"/>
      <xs:attributeGroup ref="common-attributes"/>
    </xs:complexType>
  </xs:element>

