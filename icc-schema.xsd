  <xs:element name="short-code">
    <xs:annotation>
      <xs:appinfo>
        <xs:documentation>The "shortcode" element is a short mnemonic that is used to resolve the
        url on Digital Codes. For example: 'abcde'. The shortcode will be created programmatically. </xs:documentation>
      </xs:appinfo>
    </xs:annotation>
    <xs:complexType mixed="true">
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:group ref="inline-elements"/>
      </xs:choice>
      
      <xs:attribute name="short-url" use="required" type="xs:string">
        <xs:annotation>
          <xs:appinfo>
            <xs:documentation>The "short-url" element is a url that links to Digital Codes and gets
            resolved on the backend to the full-url, i.e., http://short.iccsafe.org/abcde. </xs:documentation>
          </xs:appinfo>
        </xs:annotation>
      </xs:attribute>
    </xs:complexType>
  </xs:element>

  <xs:simpleType name="yesorno">
    <xs:restriction base="xs:string">
      <xs:enumeration value="yes"/>
      <xs:enumeration value="no"/>
    </xs:restriction>
